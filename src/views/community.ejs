<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/svg/favicon.svg">
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
    <link rel="stylesheet" type="text/css" href="/css/common.css">
    <link rel="stylesheet" type="text/css" href="/css/community.css">
    <script src="/js/jquery-3.6.0.js"></script>
    <script defer src="/js/common.js"></script>
    <script defer src="/js/community.js"></script>
    <title>커뮤니티 : 카피디아</title>
</head>

<body>
    <%- include('./includes/header') %>
    <main>
        <div class="community-container">
            <% if (mode === 'main') { %>
                <!-- 커뮤니티 메인 -->
                <div class="community-header">
                    <h1>커뮤니티</h1>
                </div>

                <!-- 인기 게시판 -->
                <% if (popularBoards && popularBoards.length > 0) { %>
                    <section class="popular-boards">
                        <div class="section-header">
                            <h2>인기 게시판</h2>
                        </div>
                        <div class="board-grid">
                            <% popularBoards.forEach((board) => { %>
                                <a class="board-card" href="/community?generationSeq=<%= board.generationSeq %>">
                                    <span class="board-manufacturer"><%= board.manufacturerName %></span>
                                    <span class="board-model"><%= board.modelName %></span>
                                    <span class="board-generation"><%= board.generationName %></span>
                                    <span class="board-count">게시글 <%= board.postCount %>건</span>
                                </a>
                            <% }) %>
                        </div>
                    </section>
                <% } %>

                <!-- 인기글 -->
                <section class="feed-section">
                    <div class="section-header">
                        <h2>인기글</h2>
                    </div>
                    <div class="post-list" id="popular-post-list">
                        <% if (popularPosts && popularPosts.length > 0) { %>
                            <% popularPosts.forEach((post) => { %>
                                <div class="post-card" data-seq="<%= post.postSeq %>">
                                    <div class="post-badges">
                                        <% if (post.manufacturerName && post.modelName) { %>
                                            <span class="post-vehicle-badge"><%= post.manufacturerName %> <%= post.modelName %> <%= post.generationName %></span>
                                        <% } %>
                                        <% if (post.category) { %>
                                            <span class="category-badge"><%= post.category %></span>
                                        <% } %>
                                    </div>
                                    <h3 class="post-title"><%= post.title %></h3>
                                    <p class="post-preview"><%= post.preview ? post.preview.substring(0, 100) : '' %></p>
                                    <div class="post-meta">
                                        <span class="post-author"><%= post.author %></span>
                                        <span class="post-date"><%= new Date(post.createAt).toLocaleDateString('ko-KR') %></span>
                                        <div class="post-stats">
                                            <span>♥ <%= post.likeCount %></span>
                                            <span>댓글 <%= post.commentCount %></span>
                                            <span>조회 <%= post.viewCount %></span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="no-posts"><p>아직 게시글이 없습니다.</p></div>
                        <% } %>
                    </div>
                    <% if (popularPosts && popularPosts.length >= 10) { %>
                        <div class="load-more-wrap">
                            <button type="button" class="load-more-btn" id="load-more-popular" data-offset="10">더보기</button>
                        </div>
                    <% } %>
                </section>

                <!-- 차종별 게시판 선택 -->
                <section class="vehicle-select-section">
                    <div class="section-header">
                        <h2>차종별 게시판</h2>
                    </div>
                    <div class="vehicle-select">
                        <div class="select-step" id="step-manufacturer">
                            <% const domesticMfrs = manufacturers.filter(m => m.countryCode === 'KR'); %>
                            <% const foreignMfrs = manufacturers.filter(m => m.countryCode !== 'KR'); %>
                            <% if (domesticMfrs.length > 0) { %>
                                <h3 class="section-title">국내 브랜드</h3>
                                <div class="select-grid">
                                    <% domesticMfrs.forEach((mfr) => { %>
                                        <button class="select-card manufacturer-card" data-seq="<%= mfr.manufacturerSeq %>">
                                            <span class="card-name"><%= mfr.manufacturerName %></span>
                                        </button>
                                    <% }) %>
                                </div>
                            <% } %>
                            <% if (foreignMfrs.length > 0) { %>
                                <h3 class="section-title">해외 브랜드</h3>
                                <div class="select-grid">
                                    <% foreignMfrs.forEach((mfr) => { %>
                                        <button class="select-card manufacturer-card" data-seq="<%= mfr.manufacturerSeq %>">
                                            <span class="card-name"><%= mfr.manufacturerName %></span>
                                        </button>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                        <div class="select-step hidden" id="step-model">
                            <div class="step-header">
                                <button type="button" class="back-step-btn" data-target="manufacturer">← 뒤로</button>
                                <h2 class="step-title">모델을 선택하세요</h2>
                            </div>
                            <div class="select-grid" id="model-grid"></div>
                        </div>
                        <div class="select-step hidden" id="step-generation">
                            <div class="step-header">
                                <button type="button" class="back-step-btn" data-target="model">← 뒤로</button>
                                <h2 class="step-title">세대를 선택하세요</h2>
                            </div>
                            <div class="select-grid" id="generation-grid"></div>
                        </div>
                    </div>
                </section>

            <% } else { %>
                <!-- 게시글 목록 페이지 -->
                <div class="community-header">
                    <div class="header-left">
                        <a href="/community" class="back-to-select">← 커뮤니티</a>
                        <h1 class="generation-title"><%= generationInfo.manufacturerName %> <%= generationInfo.modelName %> <%= generationInfo.generationName %></h1>
                    </div>
                    <button type="button" class="write-btn<%= user ? '' : ' login-required' %>" data-generation-seq="<%= generationSeq %>">글쓰기</button>
                </div>
                <div class="community-content" data-generation-seq="<%= generationSeq %>">
                    <div class="category-filter">
                        <button class="<%= !category ? 'active' : '' %>" data-category="">전체</button>
                        <button class="<%= category === '자유' ? 'active' : '' %>" data-category="자유">자유</button>
                        <button class="<%= category === '질문' ? 'active' : '' %>" data-category="질문">질문</button>
                        <button class="<%= category === '정비·튜닝' ? 'active' : '' %>" data-category="정비·튜닝">정비·튜닝</button>
                        <button class="<%= category === '후기' ? 'active' : '' %>" data-category="후기">후기</button>
                        <button class="<%= category === '사진' ? 'active' : '' %>" data-category="사진">사진</button>
                    </div>
                    <div class="post-sort">
                        <button class="<%= sort === 'latest' ? 'active' : '' %>" data-sort="latest">최신순</button>
                        <button class="<%= sort === 'popular' ? 'active' : '' %>" data-sort="popular">인기순</button>
                        <button class="<%= sort === 'views' ? 'active' : '' %>" data-sort="views">조회순</button>
                    </div>
                    <div class="post-search">
                        <input type="text" class="search-input" placeholder="제목 또는 내용으로 검색"
                               value="<%= typeof keyword !== 'undefined' && keyword ? keyword : '' %>">
                        <button type="button" class="search-btn">검색</button>
                    </div>
                    <div class="post-list">
                        <% if (postList && postList.length > 0) { %>
                            <% postList.forEach((post) => { %>
                                <div class="post-card" data-seq="<%= post.postSeq %>">
                                    <% if (post.category) { %>
                                        <span class="category-badge"><%= post.category %></span>
                                    <% } %>
                                    <h3 class="post-title"><%= post.title %></h3>
                                    <p class="post-preview"><%= post.preview ? post.preview.substring(0, 100) : '' %></p>
                                    <div class="post-meta">
                                        <span class="post-author"><%= post.author %></span>
                                        <span class="post-date"><%= new Date(post.createAt).toLocaleDateString('ko-KR') %></span>
                                        <div class="post-stats">
                                            <span>♥ <%= post.likeCount %></span>
                                            <span>댓글 <%= post.commentCount %></span>
                                            <span>조회 <%= post.viewCount %></span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="no-posts">
                                <p><%= (typeof keyword !== 'undefined' && keyword) ? '"' + keyword + '" 검색 결과가 없습니다.' : '게시글이 없습니다. 첫 게시글을 작성해보세요!' %></p>
                            </div>
                        <% } %>
                    </div>
                    <% if (totalPages > 1) { %>
                        <div class="pagination">
                            <% for (let i = 1; i <= totalPages; i++) { %>
                                <button class="page-btn <%= i === currentPage ? 'active' : '' %>" data-page="<%= i %>"><%= i %></button>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </main>
</body>

</html>
